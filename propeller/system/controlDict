FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     simpleFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         3000;
deltaT          1;

writeControl    timeStep;
writeInterval   500;
purgeWrite      3;

writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

functions
{
    forces
    {
        type            forces;
        libs            ("libforces.so");   // η βιβλιοθηκη που το παρεχει

        patches         (propeller);        // σε ποιο patch μετραμε δυναμεις

        rho             rhoInf;             // σταθερη πυκνοτητα (incompressible)
        rhoInf          999;                // πυκνοτητα νερου kg/m^3

        CofR            (0 0 0);            // Center of Rotation = κεντρο δισκου

        writeControl    timeStep;
        writeInterval   1;                  // γραψε σε καθε iteration
    }
}
