FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}

dimensions      [0 2 -1 0 0 0 0];    // m^2/s (turbulent viscosity)

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            calculated;       // ο solver το υπολογιζει απο k,omega
        value           uniform 0;
    }
    outlet
    {
        type            calculated;
        value           uniform 0;
    }
    farfield
    {
        type            calculated;
        value           uniform 0;
    }
    propeller
    {
        type            nutkWallFunction;   // ΤΟ ΚΛΕΙΔΙ: wall function y+~30
        value           uniform 0;
    }
}
