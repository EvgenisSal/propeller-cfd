FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}

dimensions      [0 2 -2 0 0 0 0];    // m^2/s^2 (κινηματικη πιεση p/rho)

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            zeroGradient;   // πιεση ελευθερη (ξερουμε U εδω)
    }
    outlet
    {
        type            fixedValue;     // πιεση ορισμενη = 0 (reference)
        value           uniform 0;
    }
    farfield
    {
        type            zeroGradient;
    }
    propeller
    {
        type            zeroGradient;   // στον τοιχο: dp/dn = 0
    }
}
