FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

dimensions      [0 2 -2 0 0 0 0];    // m^2/s^2

internalField   uniform 0.0054;      // k = 1.5*(U*I)^2, I=2%, U=3

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.0054;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.0054;
        value           uniform 0.0054;
    }
    farfield
    {
        type            slip;
    }
    propeller
    {
        type            kqRWallFunction;   // wall function για k στον τοιχο
        value           uniform 0.0054;
    }
}
